if not exist "%CONFIG_DIR%" mkdir "%CONFIG_DIR%" >nul 2>&1

call :WRITE_PY
if errorlevel 1 (
    echo [LOI] Khong tao duoc file Python tam.
    pause
    exit /b 1
)

if /I "%~1"=="--auto" (
    python "%PY_MAIN%" --action update --bat "%~f0"
    exit /b %errorlevel%
)

:MENU
cls
echo ============================================================
echo      TTCO - LAY TON KHO TU BANG KET QUA CUOI TTCO_APP v16
echo ============================================================
echo Nguon dung theo SQL live bat duoc:
echo   TTCO_THONGKE.dbo.G3_BC05A_2_######
echo.
echo Khong lay:
echo   - Excel
echo   - CDOTHAN truc tiep
echo   - G3_BC05A_1_* trung gian
echo.
echo  [1] Cap nhat GitHub ngay
echo.
echo  [2] Kiem tra bang nguon va Kho 1 truoc khi up
echo.
echo  [3] Chon lai thu muc repo GitHub my-ai-site
echo.
echo  [4] Cai dat tu dong khi dang nhap Windows
echo.
echo  [5] Mo file log
echo.
echo  [0] Thoat
echo.
echo ============================================================
choice /C 123450 /N /M "Chon chuc nang [1/2/3/4/5/0]: "

if errorlevel 6 exit /b 0
if errorlevel 5 (
    python "%PY_MAIN%" --action open-log --bat "%~f0"
    goto MENU
)
if errorlevel 4 (
    python "%PY_MAIN%" --action install --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 3 (
    python "%PY_MAIN%" --action config-repo --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 2 (
    python "%PY_MAIN%" --action check --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 1 (
    python "%PY_MAIN%" --action update --bat "%~f0"
    pause
    goto MENU
)

goto MENU

