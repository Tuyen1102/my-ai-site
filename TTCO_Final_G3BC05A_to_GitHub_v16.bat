@echo off
setlocal EnableExtensions EnableDelayedExpansion
chcp 65001 >nul
title TTCO FINAL G3_BC05A_2 to GitHub - v16

set "CONFIG_DIR=%LOCALAPPDATA%\TTCO_TonKho_Final_G3BC05A_To_GitHub"
set "PY_MAIN=%CONFIG_DIR%\TTCO_Final_G3BC05A_To_GitHub_v16.py"
