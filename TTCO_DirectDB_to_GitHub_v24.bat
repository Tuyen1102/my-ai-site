@echo off
setlocal EnableExtensions EnableDelayedExpansion
chcp 65001 >nul
title TTCO Direct DB To GitHub - v24

set "CONFIG_DIR=%LOCALAPPDATA%\TTCO_TonKho_DirectDB_V24"
set "PY_MAIN=%CONFIG_DIR%\TTCO_DirectDB_To_GitHub_v24.py"
set "B64_FILE=%CONFIG_DIR%\TTCO_DirectDB_To_GitHub_v24.b64"

if not exist "%CONFIG_DIR%" mkdir "%CONFIG_DIR%" >nul 2>&1

call :WRITE_PY
if errorlevel 1 (
    echo [LOI] Khong tao duoc file Python tam.
    pause
    exit /b 1
)

if /I "%~1"=="--auto" (
    python "%PY_MAIN%" --action update --bat "%~f0"
    exit /b %errorlevel%
)

:MENU
cls
echo ============================================================
echo      TTCO - DO TRUC TIEP DB LEN GITHUB v24
echo ============================================================
echo Nguyen nhan v23 sai:
echo   v23 KHONG thuc su dung engine v19; no fallback sang ThanVaoSang/ThanRaSang.
echo   Vi vay NhapTK=0 va XuatTK=3.660,00 bi lech.
echo.
echo v24 sua dung:
echo   1. Chay lai engine v19 de lay NhapTK/XuatTK da dung.
echo   2. Bo sung TonDK tu CDOTHAN thang truoc.
echo   3. Tinh lai TonCK = TonDK + NhapTK - XuatTK.
echo.
echo  [1] Kiem tra truc tiep DB thang hien tai, chua up GitHub
echo.
echo  [2] Cap nhat GitHub truc tiep DB thang hien tai
echo.
echo  [3] Kiem tra truc tiep DB thang tuy chon, chua up GitHub
echo.
echo  [4] Cap nhat GitHub truc tiep DB thang tuy chon
echo.
echo  [5] Chon lai thu muc repo GitHub my-ai-site
echo.
echo  [6] Cai dat tu dong khi dang nhap Windows
echo.
echo  [7] Mo file log
echo.
echo  [0] Thoat
echo.
echo ============================================================
choice /C 12345670 /N /M "Chon chuc nang [1/2/3/4/5/6/7/0]: "

if errorlevel 8 exit /b 0
if errorlevel 7 (
    python "%PY_MAIN%" --action open-log --bat "%~f0"
    goto MENU
)
if errorlevel 6 (
    python "%PY_MAIN%" --action install --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 5 (
    python "%PY_MAIN%" --action config-repo --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 4 (
    python "%PY_MAIN%" --action update-custom --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 3 (
    python "%PY_MAIN%" --action check-custom --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 2 (
    python "%PY_MAIN%" --action update --bat "%~f0"
    pause
    goto MENU
)
if errorlevel 1 (
    python "%PY_MAIN%" --action check --bat "%~f0"
    pause
    goto MENU
)

goto MENU

